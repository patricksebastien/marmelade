tests/fixtures/*.wav
tests/fixtures/*.flac
tests/fixtures/*.mp3

# GSD (get-shit-done) — local tool state, planning artifacts & agent worktrees.
# Kept local only, out of the tracked codebase, to keep the repo clean.
.gsd/
gsd-*
.planning/
# Claude Code / GSD local workspace: manifests, agent worktrees, settings.
.claude/
